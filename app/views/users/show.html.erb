<div class="mt-5 ms-3">
  <div class="row me-3"> 
  
    <div class="col-md-3">
      <%= render "users/sidebar", user: @user, book: Book.new %>
    </div>

    <div class="col-md-8 offset-md-1">
      
      <h2>Books</h2>
      <table class="table table-hover table-inverse">
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, style: "max-width: 40px; border-radius: 4px;" %>
                  <% else %>
                    <%= image_tag "no_image.jpg", style: "max-width: 40px; border-radius: 4px;" %>
                  <% end %>
                  
                <% end %>
              </td>
              <td><%= link_to book.title, book_path(book) %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

    </div>

  </div>
</div>