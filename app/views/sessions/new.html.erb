<div class="mt-3 ms-3">
  
  <h2>Log in</h2>

  <%= form_with url: session_users_path, local: true do |form| %>
    
    <div>
      <label for="user_name">Name</label><br>
      <%= form.text_field :name, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your name", value: params[:name] %><br>
    </div>
    <div>
      <label for="user_password">Password</label><br>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password" %><br>
    </div>
    <br>
    <div class="actions mb-3">
      <%= form.submit "Log in", class: "btn btn-sm btn-primary" %>
    </div>
  <% end %>
  <br>
  
  <%= link_to "Sign up", new_user_path %><br>
  <%= link_to "Forgot password?", new_password_path %>
</div>
