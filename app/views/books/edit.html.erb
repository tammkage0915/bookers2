<div class="container mt-3">
  <div class="row">
    <div class="col-sm-12 col-md-8 col-lg-6 mx-auto">
      
      <h2>Editing Book</h2>
      
      <%= form_with model: @book, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :title, "Title", class: "form-label" %>
          <%= form.text_field :title, class: "form-control", id: "book_title", required: true %>
        </div>

        <div class="mb-3">
          <%= form.label :body, "Opinion", class: "form-label" %>
          <%= form.text_area :body, class: "form-control", id: "book_body", required: true %>
        </div>

        <div class="mb-3">
          <%= form.submit "Update Book", class: "btn btn-success" %>
        </div>
      <% end %>

      <div class="mt-3">
        <%= link_to "Show", book_path(@book) %>
        |
        <%= link_to "Back", books_path %>
      </div>

    </div>
  </div>
</div>
